# PostHog
POSTHOG_API_KEY=phx_your_api_key_here
POSTHOG_PROJECT_ID=your_project_id
POSTHOG_API_URL=https://us.posthog.com

# Microsoft Clarity
CLARITY_API_KEY=your_clarity_api_token
CLARITY_PROJECT_ID=your_clarity_project_id
CLARITY_API_URL=https://www.clarity.ms/export/api/v1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=lucent:

# Pipeline
PIPELINE_QUEUE_NAME=lucent:ingestion
PIPELINE_DLQ_NAME=lucent:ingestion:dlq
PIPELINE_CONCURRENCY=5
PIPELINE_MAX_RETRIES=3
PIPELINE_RETRY_DELAY_MS=1000

# Logging
LOG_LEVEL=info
NODE_ENV=development

